  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "jest": "^29.0.0",
    "supertest": "^7.2.2",
    "@types/jest": "^29.0.0",
    "nodemon": "^3.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.(test|spec).js"],
    "testPathIgnorePatterns": ["/node_modules/", "/tests/e2e/"],
